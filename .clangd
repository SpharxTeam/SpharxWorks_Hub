---
# Clangd 配置文件
# 文档：https://clangd.llvm.org/config

If:
  PathMatch: "**/*"
CompileFlags:
  # 添加额外的包含路径
  Add: [
    "-I${workspaceFolder}/AgentOS/coreadd/core/include",
    "-I${workspaceFolder}/AgentOS/coreadd/memoryrovol/include",
    "-I${workspaceFolder}/AgentOS/coreadd/coreloopthree/include",
    "-I${workspaceFolder}/AgentOS/coreadd/syscall/include",
    "-I${workspaceFolder}/AgentOS/coreadd/utils/include",
  ]
  
  # 定义宏
  Add: [
    "-DAGENTOS_VERSION=\"3.0.0\"",
    "-D_GNU_SOURCE",
    "-D_WIN32",
    "-D_WINDOWS",
    "-D_CRT_SECURE_NO_WARNINGS",
  ]
  
  # C 标准设置
  Compiler: "cl"
  Standard: "c11"

Diagnostics:
  # 启用所有诊断
  Suppress: []
  WarningsAsErrors: []
  
Completion:
  # 详细的补全风格
  Style: Detailed
  # 包含所有作用域的补全
  AllScopesCompletions: true
  # 过滤补全结果
  FilterSoundness: Complete
  
Index:
  # 启用后台索引
  Background: Build
  # 索引所有文件
  Standard: All
  
InlayHints:
  # 参数名称提示
  ParameterNames: true
  # 类型提示
  TypeHints: true
  # 变量初始化类型提示
  VariableTypes: true
  
Hover:
  # 悬停显示更多信息
  ShowAKA: true
  ShowCategory: true
  LocalVariables: true

SignatureHelp:
  # 签名帮助
  IncludeStyles: true
  
Format:
  # 代码格式化配置
  BasedOnStyle: LLVM
  IndentWidth: 4
  TabWidth: 4
  UseTab: Never
  ColumnLimit: 120
  AccessModifierOffset: -4
  AlignAfterOpenBracket: true
  AlignConsecutiveAssignments: false
  AlignConsecutiveDeclarations: false
  AllowShortBlocksOnASingleLine: false
  AllowShortCaseLabelsOnASingleLine: false
  AllowShortFunctionsOnASingleLine: None
  AllowShortIfStatementsOnASingleLine: false
  AllowShortLoopsOnASingleLine: false
  AlwaysBreakAfterReturnType: None
  AlwaysBreakBeforeMultilineStrings: true
  BinPackArguments: true
  BinPackParameters: true
  BreakBeforeBraces: Attach
  BreakBeforeTernaryOperators: true
  BreakConstructorInitializersBeforeComma: false
  BreakStringLiterals: true
  CompactNamespaces: false
  ContinuationIndentWidth: 4
  DerivePointerAlignment: false
  DisableFormat: false
  ExperimentalAutoDetectBinPacking: false
  ForEachMacros: ["foreach", "Q_FOREACH", "BOOST_FOREACH"]
  IncludeCategories:
    - Regex: '^<.*\.h>'
      Priority: 1
    - Regex: '^<.*>'
      Priority: 2
    - Regex: '.*'
      Priority: 3
  IncludeIsMainRegex: '([-_](test|unittest))?$'
  KeepEmptyLinesAtTheStartOfBlocks: false
  MacroBlockBegin: ''
  MacroBlockEnd: ''
  MaxEmptyLinesToKeep: 1
  NamespaceIndentation: None
  ObjCBlockIndentWidth: 2
  PointerAlignment: Left
  ReflowComments: true
  SortIncludes: CaseInsensitive
  SpaceAfterCStyleCast: false
  SpaceAfterTemplateKeyword: true
  SpaceBeforeAssignmentOperators: true
  SpaceBeforeCpp11BracedList: false
  SpaceBeforeCtorInitializerColon: true
  SpaceBeforeInheritanceColon: true
  SpaceBeforeParens: ControlStatements
  SpaceBeforeRangeBasedForLoopColon: true
  SpaceInEmptyParentheses: false
  SpacesBeforeTrailingComments: 1
  SpacesInAngles: false
  SpacesInContainerLiterals: true
  SpacesInCStyleCastParentheses: false
  SpacesInParentheses: false
  SpacesInSquareBrackets: false
  Standard: c11

If:
  PathMatch: '**/memoryrovol/**'
CompileFlags:
  Add: [-DMAPI_ENABLE=1]
